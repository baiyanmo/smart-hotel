.container { max-width:1200px; margin:0 auto; padding:0 24rpx; }
.card { background:rgba(0,20,40,0.7); border:1rpx solid rgba(0,255,255,0.15); border-radius:16rpx; padding:24rpx; margin-bottom:24rpx; }
.title { font-size:36rpx; font-weight:700; color:#e0f7fa; margin-bottom:16rpx; }
.label { font-size:28rpx; color:rgba(0,255,255,0.6); margin-bottom:8rpx; }
.input { width:100%; height:88rpx; background:rgba(255,255,255,0.05); border:1rpx solid rgba(0,255,255,0.2); border-radius:12rpx; padding:0 24rpx; color:#e0f7fa; font-size:30rpx; }
.btn-primary { display:flex; align-items:center; justify-content:center; height:88rpx; background:linear-gradient(135deg, #006064, #00bcd4); color:#000; border-radius:44rpx; font-size:32rpx; font-weight:600; border:none; }
.btn-secondary { display:flex; align-items:center; justify-content:center; height:88rpx; background:rgba(0,255,255,0.1); border:1rpx solid rgba(0,255,255,0.3); color:#00e5ff; border-radius:44rpx; font-size:32rpx; }
.empty { text-align:center; color:rgba(0,255,255,0.4); font-size:28rpx; padding:80rpx 0; }
