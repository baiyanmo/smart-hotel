<view class="container rooms-page">
  <scroll-view class="filter-bar" scroll-x>
    <view
      class="filter-tag {{currentType === '' ? 'active' : ''}}"
      wx:for="{{types}}"
      wx:key="*this"
      wx:for-item="t"
      wx:for-index="i"
      data-index="{{i}}"
      bindtap="onFilter"
    >{{typeLabels[i]}}</view>
  </scroll-view>

  <view class="room-list">
    <view class="room-card card" wx:for="{{rooms}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="room-header">
        <view class="room-number">{{item.room_number}}</view>
        <view class="room-badge badge-{{item.type}}">{{typeLabels[types.indexOf(item.type)] || item.type}}</view>
      </view>
      <view class="room-info">
        <text class="room-price">¥{{item.price}}<text class="price-unit">/晚</text></text>
        <text class="room-floor">{{item.floor}}层</text>
      </view>
      <view class="room-desc">{{item.description || '暂无描述'}}</view>
    </view>
  </view>

  <view class="empty" wx:if="{{rooms.length === 0}}">暂无可用房间</view>
</view>
