.rooms-page { padding-top:24rpx; }
.filter-bar { display:flex; white-space:nowrap; padding:0 0 20rpx; }
.filter-tag { display:inline-block; padding:12rpx 28rpx; margin-right:16rpx; background:rgba(255,255,255,0.05); border:1rpx solid rgba(0,255,255,0.15); border-radius:32rpx; font-size:26rpx; color:rgba(255,255,255,0.5); }
.filter-tag.active { background:rgba(0,255,255,0.15); border-color:rgba(0,255,255,0.4); color:#00e5ff; }

.room-card { margin-bottom:16rpx; }
.room-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:12rpx; }
.room-number { font-size:32rpx; font-weight:600; color:#e0f7fa; }
.room-badge { padding:4rpx 16rpx; border-radius:8rpx; font-size:22rpx; }
.badge-standard { background:rgba(0,188,212,0.2); color:#00bcd4; }
.badge-deluxe { background:rgba(156,39,176,0.2); color:#ce93d8; }
.badge-suite { background:rgba(255,152,0,0.2); color:#ffb74d; }
.badge-presidential { background:rgba(244,67,54,0.2); color:#ef9a9a; }
.room-info { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8rpx; }
.room-price { font-size:36rpx; font-weight:700; color:#00e5ff; }
.price-unit { font-size:24rpx; font-weight:400; color:rgba(0,229,255,0.5); }
.room-floor { font-size:26rpx; color:rgba(255,255,255,0.4); }
.room-desc { font-size:26rpx; color:rgba(255,255,255,0.5); }
