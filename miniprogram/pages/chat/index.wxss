.chat-page { display:flex; flex-direction:column; height:100vh; }
.chat-list { flex:1; padding:24rpx; }
.msg-row { margin-bottom:24rpx; }
.msg-row.msg-user { display:flex; flex-direction:column; align-items:flex-end; }
.msg-row.msg-ai { display:flex; flex-direction:column; align-items:flex-start; }
.msg-bubble { max-width:70%; padding:16rpx 24rpx; border-radius:16rpx; font-size:30rpx; line-height:1.6; }
.msg-bubble.user { background:linear-gradient(135deg, #006064, #00bcd4); color:#000; border-bottom-right-radius:4rpx; }
.msg-bubble.ai { background:rgba(0,255,255,0.1); color:#e0f7fa; border:1rpx solid rgba(0,255,255,0.15); border-bottom-left-radius:4rpx; }
.msg-time { font-size:22rpx; color:rgba(255,255,255,0.3); margin-top:4rpx; }

.chat-input-bar { display:flex; align-items:center; padding:16rpx; background:rgba(0,20,40,0.95); border-top:1rpx solid rgba(0,255,255,0.1); }
.voice-btn { width:120rpx; height:72rpx; display:flex; align-items:center; justify-content:center; background:rgba(0,255,255,0.1); border:1rpx solid rgba(0,255,255,0.2); border-radius:36rpx; font-size:22rpx; color:#00e5ff; margin-right:12rpx; }
.voice-btn.recording { background:rgba(255,0,80,0.2); border-color:rgba(255,0,80,0.4); color:#ff4080; animation:pulse 0.5s infinite alternate; }
.chat-input { flex:1; height:72rpx; background:rgba(255,255,255,0.05); border:1rpx solid rgba(0,255,255,0.15); border-radius:36rpx; padding:0 24rpx; color:#e0f7fa; font-size:28rpx; }
.send-btn { margin-left:12rpx; padding:0 28rpx; height:72rpx; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg, #006064, #00bcd4); color:#000; border-radius:36rpx; font-size:28rpx; font-weight:600; }

@keyframes pulse { from{opacity:1;} to{opacity:0.5;} }
