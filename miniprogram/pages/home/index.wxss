.home-page { padding-top:24rpx; }
.weather-panel { background:linear-gradient(135deg, rgba(0,96,100,0.6), rgba(0,188,212,0.3)); border:1rpx solid rgba(0,255,255,0.2); border-radius:20rpx; padding:32rpx; margin-bottom:24rpx; text-align:center; }
.weather-city { font-size:28rpx; color:rgba(255,255,255,0.6); }
.weather-temp { font-size:72rpx; font-weight:700; color:#00e5ff; line-height:1.2; }
.weather-desc { font-size:26rpx; color:rgba(255,255,255,0.7); margin-top:8rpx; }

.ai-card { display:flex; align-items:center; padding:32rpx; margin-bottom:24rpx; background:linear-gradient(135deg, rgba(0,255,255,0.1), rgba(0,188,212,0.05)); border:1rpx solid rgba(0,255,255,0.2); }
.ai-avatar { font-size:56rpx; margin-right:20rpx; }
.ai-info { flex:1; }
.ai-title { font-size:34rpx; font-weight:600; color:#e0f7fa; }
.ai-subtitle { font-size:26rpx; color:rgba(0,255,255,0.5); margin-top:4rpx; }
.ai-arrow { font-size:40rpx; color:rgba(0,255,255,0.4); }

.quick-grid { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; }
.quick-item { display:flex; flex-direction:column; align-items:center; padding:32rpx 16rpx; }
.quick-icon { font-size:48rpx; margin-bottom:12rpx; }
.quick-label { font-size:26rpx; color:rgba(255,255,255,0.7); }
