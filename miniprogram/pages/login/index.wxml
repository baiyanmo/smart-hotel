<view class="container login-page">
  <view class="login-logo">🏨</view>
  <view class="login-title">{{isRegister ? '注册' : '登录'}}智慧酒店</view>

  <view class="card">
    <view class="form-row"><text class="label">用户名</text></view>
    <input class="input" placeholder="请输入用户名" value="{{username}}" data-field="username" bindinput="onInput" />
    <view class="form-row" style="margin-top:24rpx"><text class="label">密码</text></view>
    <input class="input" type="password" placeholder="请输入密码" value="{{password}}" data-field="password" bindinput="onInput" />
  </view>

  <button class="btn-primary" bindtap="onSubmit">{{isRegister ? '注册' : '登录'}}</button>
  <view class="toggle-text" bindtap="toggleMode">
    {{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}
  </view>
</view>
