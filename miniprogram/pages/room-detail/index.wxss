.detail-page { padding-top:24rpx; }
.detail-header { text-align:center; padding:40rpx; margin-bottom:24rpx; }
.detail-number { font-size:48rpx; font-weight:700; color:#00e5ff; }
.detail-type { display:inline-block; padding:6rpx 20rpx; border-radius:8rpx; font-size:24rpx; margin:12rpx 0; }
.detail-price { font-size:40rpx; font-weight:700; color:#e0f7fa; }
.unit { font-size:24rpx; font-weight:400; color:rgba(255,255,255,0.4); }
.detail-floor { font-size:26rpx; color:rgba(255,255,255,0.4); margin-top:8rpx; }

.section-title { font-size:32rpx; font-weight:600; color:#e0f7fa; margin-bottom:20rpx; }
.form-row { margin-bottom:20rpx; }
.price-row { display:flex; justify-content:space-between; align-items:center; padding-top:20rpx; border-top:1rpx solid rgba(0,255,255,0.1); font-size:30rpx; color:rgba(255,255,255,0.6); }
.total-price { font-size:40rpx; font-weight:700; color:#00e5ff; }
