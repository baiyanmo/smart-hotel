<view class="container detail-page" wx:if="{{room}}">
  <view class="detail-header card">
    <view class="detail-number">{{room.room_number}}</view>
    <view class="detail-type badge-{{room.type}}">{{room.type}}</view>
    <view class="detail-price">¥{{room.price}} <text class="unit">/ 晚</text></view>
    <view class="detail-floor">{{room.floor}}层 | {{room.status === 'available' ? '可预订' : '已占用'}}</view>
  </view>

  <view class="card">
    <view class="section-title">预订信息</view>
    <view class="form-row">
      <text class="label">入住日期</text>
      <input class="input" type="date" value="{{checkInDate}}" bindchange="onCheckInChange" />
    </view>
    <view class="form-row">
      <text class="label">退房日期</text>
      <input class="input" type="date" value="{{checkOutDate}}" bindchange="onCheckOutChange" />
    </view>
    <view class="form-row">
      <text class="label">入住姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{guestName}}" bindinput="e=>setData({guestName:e.detail.value})" />
    </view>
    <view class="form-row">
      <text class="label">联系电话</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{guestPhone}}" bindinput="e=>setData({guestPhone:e.detail.value})" />
    </view>

    <view class="price-row" wx:if="{{days > 0}}">
      <text>共 {{days}} 晚 · 合计</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
  </view>

  <button class="btn-primary" bindtap="onSubmit" wx:if="{{room.status === 'available'}}">立即预订</button>
  <view class="btn-primary disabled" wx:else>该房间暂不可预订</view>
</view>
