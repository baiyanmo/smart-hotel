<view class="container orders-page">
  <view class="order-card card" wx:for="{{orders}}" wx:key="id">
    <view class="order-header">
      <view class="order-room">房间 {{item.room_id}}</view>
      <view class="order-status status-{{item.status}}">{{getStatusText(item.status)}}</view>
    </view>
    <view class="order-dates">
      <text>{{item.check_in}} → {{item.check_out}}</text>
    </view>
    <view class="order-footer">
      <text class="order-price">¥{{item.total_price}}</text>
      <view wx:if="{{item.status === 'pending'}}" class="btn-cancel" data-id="{{item.id}}" bindtap="onCancel">取消</view>
    </view>
  </view>
  <view class="empty" wx:if="{{orders.length === 0}}">暂无订单</view>
</view>
