.orders-page { padding-top:24rpx; }
.order-card { margin-bottom:16rpx; }
.order-header { display:flex; justify-content:space-between; margin-bottom:8rpx; }
.order-room { font-size:30rpx; font-weight:600; color:#e0f7fa; }
.order-status { font-size:24rpx; padding:4rpx 12rpx; border-radius:8rpx; }
.status-pending { background:rgba(255,152,0,0.2); color:#ffb74d; }
.status-confirmed { background:rgba(0,188,212,0.2); color:#00bcd4; }
.status-checked_in { background:rgba(76,175,80,0.2); color:#81c784; }
.status-completed { background:rgba(76,175,80,0.1); color:#a5d6a7; }
.status-cancelled { background:rgba(244,67,54,0.1); color:#ef9a9a; }
.order-dates { font-size:26rpx; color:rgba(255,255,255,0.5); margin-bottom:12rpx; }
.order-footer { display:flex; justify-content:space-between; align-items:center; }
.order-price { font-size:32rpx; font-weight:700; color:#00e5ff; }
.btn-cancel { padding:8rpx 24rpx; border:1rpx solid rgba(244,67,54,0.3); border-radius:20rpx; font-size:24rpx; color:#ef9a9a; }
